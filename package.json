{
  "name": "clipvault",
  "version": "0.0.1",
  "description": "ClipVault — A premium clipboard manager for your Mac menu bar",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "lint": "eslint src/main.js src/app.js",
    "test": "jest --selectProjects unit",
    "test:functional": "jest --selectProjects functional",
    "test:all": "jest",
    "test:coverage": "jest --selectProjects unit --coverage",
    "security:audit": "node tests/security/electron-audit.js",
    "audit:deps": "npm audit --audit-level=high",
    "dist:mac": "electron-builder --mac dmg",
    "dist:mas": "electron-builder --mac mas"
  },
  "keywords": [
    "clipboard",
    "manager",
    "menubar",
    "mac"
  ],
  "author": "ClipVault",
  "license": "MIT WITH Commons-Clause",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.50.0",
    "electron-playwright-helpers": "^1.7.1"
  },
  "build": {
    "appId": "com.clipvault.app",
    "productName": "ClipVault",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "mas": {
      "category": "public.app-category.utilities",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile",
      "hardenedRuntime": false,
      "target": [
        {
          "target": "mas",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "files": [
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}